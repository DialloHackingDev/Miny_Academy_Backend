# Configuration MongoDB pour Docker
# Pour Docker local (service mongo):
MB_url=mongodb://admin:secretpassword@mongo:27017/academy?authSource=admin

# Pour Docker avec credentials (alternative):
# MB_url=mongodb://mongo:27017/academy

# Port de l'application
PORT=5000

# JWT Secret
JWT_SECRET=votre_secret_jwt_tres_securise

# Environment
NODE_ENV=development
